<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="INF._04_01_21._06_SG_mobilna_.MainPage">

      <ScrollView>
        <VerticalStackLayout
 
            Spacing="25">
            <Label
                Text="Rejestruj konto"
                BackgroundColor="Teal"
                TextColor="White"
                FontSize="40"/>
            <Label
                Text="Podaj e-mail:"/>

            <Entry
                x:Name="email"
                Placeholder="E-mail"/>

            <Label
                Text="Podaj hasło:"/>

            <Entry
                x:Name="password"
                IsPassword="True"/>

            <Label
                Text="Powtórz hasło:"/>

            <Entry
                x:Name="repeatedPassword"
                IsPassword="true"/>

            <Button
                Text="ZATWIERDŹ"
                HorizontalOptions="Center"
                Clicked="submitLog"/>

            <Label
                x:Name="mailLabel"
                Text="Autor mati67"
                HorizontalOptions="Center"/>
        </VerticalStackLayout>
    </ScrollView>



</ContentPage>
